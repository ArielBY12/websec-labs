<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>WebSec Labs</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <header>
    <h1>🛡️ WebSec Labs</h1>
    <p class="tagline">Level-based, intentionally vulnerable web labs — OWASP Top 10 and beyond.</p>
  </header>

  <main>
    <% const levels = Object.keys(byLevel).sort((a,b)=>a-b); %>
    <% if (levels.length === 0) { %>
      <p class="empty">No labs yet. Add <code>labs/&lt;id&gt;/lab.json</code> to get started.</p>
    <% } %>
    <% levels.forEach((level) => { %>
      <section class="level">
        <h2>Level <%= level %><% if (LEVELS[level]) { %> — <%= LEVELS[level].name %><% } %></h2>
        <% if (LEVELS[level] && LEVELS[level].blurb) { %>
          <p class="level-blurb"><%= LEVELS[level].blurb %></p>
        <% } %>
        <div class="grid">
          <% byLevel[level].forEach((lab) => { %>
            <article class="card status-<%= lab.status || 'todo' %> <%= lab.mobileFriendly === false ? 'desktop-only' : '' %>">
              <div class="card-head">
                <span class="badge difficulty-<%= lab.difficulty || 'easy' %>"><%= lab.difficulty || 'easy' %></span>
                <% if (lab.stages && lab.stages.length) { %>
                  <span class="badge stages-badge"><%= lab.stages.length %> stages</span>
                <% } %>
                <span class="status-dot" title="<%= lab.status || 'todo' %>"></span>
              </div>
              <h3><a href="/lab/<%= lab.id %>"><%= lab.title %></a></h3>
              <% if (lab.mobileFriendly === false) { %>
                <details class="desktop-only-note">
                  <summary>🖥️ Desktop only</summary>
                  Needs an intercepting proxy or CLI (e.g. Burp, curl) — open this
                  lab from a computer.
                </details>
              <% } %>
              <p class="owasp"><%= lab.owasp || lab.category || '' %></p>
              <p class="summary"><%= lab.summary || '' %></p>
              <div class="tags">
                <% (lab.tags || []).forEach((t) => { %><span class="tag"><%= t %></span><% }); %>
              </div>
              <div class="card-foot">
                <code class="lab-id"><%= lab.id %></code>
                <a class="writeup-link" href="/lab/<%= lab.id %>/writeup">📖 writeup</a>
              </div>
            </article>
          <% }); %>
        </div>
      </section>
    <% }); %>
  </main>

  <footer>
    <p>⚠️ Intentionally vulnerable. Run locally only.</p>
  </footer>
</body>
</html>
